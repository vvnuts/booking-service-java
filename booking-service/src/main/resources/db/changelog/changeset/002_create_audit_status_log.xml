<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002_create_audit_status_log"
               author="vvnuts">

        <comment>Create audit_status_log table for booking status changes</comment>

        <createTable tableName="audit_status_log">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="previous_status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="new_status" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="changed_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="reason" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="initiator" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="audit_status_log"
                                 baseColumnNames="booking_id"
                                 constraintName="fk_audit_status_log_booking"
                                 referencedTableName="bookings"
                                 referencedColumnNames="id"/>

        <createIndex indexName="idx_audit_status_log_booking_changed_at_id"
                     tableName="audit_status_log">
            <column name="booking_id"/>
            <column name="changed_at" descending="true"/>
            <column name="id" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable tableName="audit_status_log"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
